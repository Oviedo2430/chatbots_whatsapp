    {
      "parameters": {
        "jsCode": "const original = $input.first().json;\nlet texto = original.output.mensaje_whatsapp || '';\nlet partes = texto.split('|||').map(t => t.trim()).filter(t => t.length > 0);\nif (partes.length === 0) partes = [texto]; // Fallback\nreturn partes.map(p => { \n  let newJson = JSON.parse(JSON.stringify(original));\n  newJson.output.mensaje_whatsapp_chunk = p;\n  return { json: newJson };\n});"
      },
