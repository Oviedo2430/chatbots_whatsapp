      "parameters": {
        "jsCode": "let md = \"MODELO | VARIANTE (Talla/Color) | PRECIO | ID_PRODUCTO | ID_VARIANTE\\n---|---|---|---|---\\n\";\nfor (let zapato of $input.all()) {\n  for (let v of zapato.json.variants) {\n    // Aseguramos que el precio no tenga decimales innecesarios para evitar confusiones de la IA\n    let price_str = String(v.price).replace('.00', '');\n    md += `${zapato.json.title} | ${v.title} | ${price_str} | ${zapato.json.id} | ${v.id}\\n`;\n  }\n}\nreturn [{ json: { catalogo_markdown: md } }];"
      },
