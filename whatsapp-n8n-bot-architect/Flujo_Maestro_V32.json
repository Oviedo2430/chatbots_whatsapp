        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"mensaje_whatsapp\": {\n      \"type\": \"string\"\n    },\n    \"estado_embudo\": {\n      \"type\": \"string\"\n    },\n    \"datos_extraidos\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"nombre\": {\n          \"type\": \"string\"\n        },\n        \"direccion\": {\n          \"type\": \"string\"\n        },\n        \"ciudad\": {\n          \"type\": \"string\",\n          \"description\": \"Municipio exacto del env\\u00edo\"\n        },\n        \"departamento\": {\n          \"type\": \"string\",\n          \"description\": \"Departamento oficial en Colombia. Infi\\u00e9relo autom\\u00e1ticamente basado en la ciudad si el cliente no lo da expl\\u00edcitamente.\"\n        },\n        \"telefono\": {\n          \"type\": \"string\"\n        },\n        \"talla\": {\n          \"type\": \"string\"\n        },\n        \"color\": {\n          \"type\": \"string\"\n        },\n        \"referencia\": {\n          \"type\": \"string\"\n        },\n        \"id_producto\": {\n          \"type\": \"string\",\n          \"description\": \"Busca el producto elegido en el cat\\u00e1logo y COPIA EXACTAMENTE el n\\u00famero num\\u00e9rico de id_producto.\"\n        },\n        \"id_variante\": {\n          \"type\": \"string\",\n          \"description\": \"Busca la variante exacta que coincida con la talla y color elegidos y COPIA EXACTAMENTE su variant_id num\\u00e9rico.\"\n        },\n        \"precio_unitario\": {\n          \"type\": \"string\",\n          \"description\": \"Copia exacta del campo precio del cat\\u00e1logo.\"\n        }\n      }\n    }\n  },\n  \"required\": [\n    \"mensaje_whatsapp\",\n    \"estado_embudo\",\n    \"datos_extraidos\"\n  ]\n}"
