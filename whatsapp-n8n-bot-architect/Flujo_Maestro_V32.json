        "jsonBody": "={\n  \"order\": {\n    \"financial_status\": \"pending\",\n    \"email\": \"{{ $json.output.datos_extraidos.telefono }}@whatsapp.com\",\n    \"tags\": \"Whatsapp\",\n    \"shipping_address\": {\n      \"first_name\": \"{{ $json.output.datos_extraidos.nombre }}\",\n      \"last_name\": \".\",\n      \"address1\": \"{{ $json.output.datos_extraidos.direccion }}\",\n      \"city\": \"{{ $json.output.datos_extraidos.ciudad }}\",\n      \"province\": \"{{ $json.output.datos_extraidos.departamento }}\",\n      \"phone\": \"{{ $json.output.datos_extraidos.telefono }}\",\n      \"country\": \"Colombia\"\n    },\n    \"line_items\": [\n      {\n        \"product_id\": {{ Number($json.output.datos_extraidos.id_producto) || null }},\n        \"variant_id\": {{ Number($json.output.datos_extraidos.id_variante) || null }},\n        \"title\": \"{{ $json.output.datos_extraidos.referencia }}\",\n        \"quantity\": 1\n      }\n    ]\n  }\n}",
