    {
      "parameters": {
        "jsCode": "const remoteJid = $('Webhook').first().json.body.data.key.remoteJid;\nconst rows = $input.all().map(i => i.json).filter(i => i.telefono === remoteJid);\nif (rows.length === 0) {\n  return []; // Ya fue procesado por otra ejecución\n}\n// Buscar el timestamp más reciente\nlet maxTimestamp = 0;\nrows.forEach(r => {\n  if (r.timestamp > maxTimestamp) maxTimestamp = r.timestamp;\n});\nconst now = Date.now();\n// Si la diferencia es menor a 59 segundos, significa que entró OTRO mensaje después de nosotros, por lo que nosotros morimos y dejamos que el OTRO proceso responda.\nlet isManual = false;\ntry { isManual = ($execution.mode === 'manual'); } catch(e) {}\nif (!isManual && (now - maxTimestamp < 14000)) {\n  return []; \n}\n// ¡Somos el último proceso! Unimos todos los mensajes\nconst combined = rows.sort((a,b) => a.timestamp - b.timestamp).map(r => r.mensaje).join('\\n');\nreturn [{ json: { combined_message: combined, telefono: remoteJid } }];"
      },
      "id": "a3ba16c9-7225-49f7-b293-4cee0d8bb2f3",
      "name": "Evaluar y Combinar",
